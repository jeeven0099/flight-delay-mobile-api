FROM python:3.11-slim

WORKDIR /app

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

COPY requirements-mobile-api.txt /app/requirements-mobile-api.txt
RUN pip install --no-cache-dir -r /app/requirements-mobile-api.txt

COPY . /app

EXPOSE 8000

CMD ["sh", "-c", "uvicorn 12_mobile_api:app --host 0.0.0.0 --port ${PORT:-10000}"]
